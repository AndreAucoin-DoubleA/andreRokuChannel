<?xml version="1.0" encoding="utf-8"?>
<component name="MoviePosterItem" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/pages/MoviePosterItem.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged"/>
    </interface>

    <children>
        <Poster
            id="poster"
            width="200"
            height="300"
            loadDisplayMode="scaleToZoom"/>
        <Label
            id="title"
            translation="[0,304]"
            width="200"
            font="font:SmallSystemFont"
            color="#FFFFFF"
            wrap="true"/>
    </children>
</component>
