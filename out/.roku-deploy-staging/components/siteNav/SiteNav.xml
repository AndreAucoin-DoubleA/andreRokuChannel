<?xml version="1.0" encoding="utf-8" ?>
<component name="SiteNav" extends="Group">
    <interface>
        <field id="itemFocused" type="integer" value="0" alwaysNotify="true" />
        <field id="itemSelected" type="integer" value="-1" alwaysNotify="true" />
        <field id="collapsed" type="boolean" value="false" onChange="onCollapsedChanged" />
        <function name="setFocusToList" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/siteNav/SiteNav.brs" />
    <script type="text/brightscript" uri="pkg:/source/bslib.brs" />
    <children>
        <Rectangle id="navBackground" width="300" height="210" color="#1a1a2e" />
        <Animation id="collapseAnim" duration="0.2" easeFunction="outQuad" optional="true">
            <FloatFieldInterpolator id="widthInterp" key="[0.0, 1.0]" keyValue="[300, 300]" fieldToInterp="navBackground.width" />
        </Animation>
        <MarkupList id="menuList" itemComponentName="NavItem" translation="[0,0]" itemSize="[300,70]" drawFocusFeedback="false" vertFocusAnimationStyle="floatingFocus" />
    </children>
</component>
